generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Shop (tenant root) ───────────────────────────────────────────────────────

model Shop {
  id           String        @id @default(cuid())
  name         String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  staff        Staff[]
  subscription Subscription?
  ingredients  Ingredient[]
  menuItems    MenuItem[]
  sales        Sale[]
}

// ─── Pre-payment registration ─────────────────────────────────────────────────

enum PendingStatus {
  AWAITING_PAYMENT
  PAID
  COMPLETED
}

model PendingRegistration {
  id               String        @id @default(cuid())
  token            String        @unique
  email            String
  billingCycle     BillingCycle
  status           PendingStatus @default(AWAITING_PAYMENT)
  xenditInvoiceId  String?
  xenditPaymentUrl String?
  createdAt        DateTime      @default(now())
  expiresAt        DateTime
}

// ─── Staff ────────────────────────────────────────────────────────────────────

model Staff {
  id            String         @id @default(cuid())
  shopId        String
  shop          Shop           @relation(fields: [shopId], references: [id])
  name          String
  email         String         @unique
  password      String
  role          StaffRole
  status        StaffStatus    @default(ACTIVE)
  phone         String?
  joinedAt      DateTime       @default(now())
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  attendance    Attendance[]
  leaveRequests LeaveRequest[]
}

enum StaffRole {
  OWNER
  MANAGER
  BARISTA
}

enum StaffStatus {
  ACTIVE
  INACTIVE
}

// ─── Attendance & Leave ───────────────────────────────────────────────────────

model Attendance {
  id        String           @id @default(cuid())
  staffId   String
  staff     Staff            @relation(fields: [staffId], references: [id], onDelete: Cascade)
  date      DateTime         @db.Date
  timeIn    DateTime?
  timeOut   DateTime?
  status    AttendanceStatus @default(PRESENT)
  note      String?
  createdAt DateTime         @default(now())

  @@unique([staffId, date])
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
}

model LeaveRequest {
  id        String      @id @default(cuid())
  staffId   String
  staff     Staff       @relation(fields: [staffId], references: [id], onDelete: Cascade)
  type      LeaveType
  startDate DateTime    @db.Date
  endDate   DateTime    @db.Date
  reason    String?
  status    LeaveStatus @default(PENDING)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

enum LeaveType {
  SICK
  ANNUAL
  EMERGENCY
  OTHER
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─── Inventory ────────────────────────────────────────────────────────────────

model Ingredient {
  id            String       @id @default(cuid())
  shopId        String
  shop          Shop         @relation(fields: [shopId], references: [id])
  name          String
  unit          String
  currentStock  Float        @default(0)
  lowStockAlert Float        @default(0)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  stockLogs     StockLog[]
  recipeItems   RecipeItem[]
}

model StockLog {
  id           String     @id @default(cuid())
  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  type         StockType
  quantity     Float
  note         String?
  createdAt    DateTime   @default(now())
}

enum StockType {
  STOCK_IN
  STOCK_OUT
}

// ─── Menu ─────────────────────────────────────────────────────────────────────

model MenuItem {
  id        String       @id @default(cuid())
  shopId    String
  shop      Shop         @relation(fields: [shopId], references: [id])
  name      String
  category  String
  price     Float
  status    MenuStatus   @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  saleItems SaleItem[]
  recipe    RecipeItem[]
}

enum MenuStatus {
  ACTIVE
  INACTIVE
}

model RecipeItem {
  id           String     @id @default(cuid())
  menuItemId   String
  menuItem     MenuItem   @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  quantity     Float
}

// ─── Sales ────────────────────────────────────────────────────────────────────

model Sale {
  id            String        @id @default(cuid())
  shopId        String
  shop          Shop          @relation(fields: [shopId], references: [id])
  total         Float
  paymentMethod PaymentMethod
  note          String?
  soldAt        DateTime      @default(now())
  createdAt     DateTime      @default(now())
  items         SaleItem[]
}

enum PaymentMethod {
  CASH
  CARD
  EWALLET
}

model SaleItem {
  id         String   @id @default(cuid())
  saleId     String
  sale       Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
  quantity   Int
  price      Float
  subtotal   Float
}

// ─── Subscription ─────────────────────────────────────────────────────────────

enum BillingCycle {
  MONTHLY
  ANNUAL
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  PENDING_PAYMENT
}

model Subscription {
  id                 String             @id @default(cuid())
  shopId             String             @unique
  shop               Shop               @relation(fields: [shopId], references: [id])
  billingCycle       BillingCycle
  status             SubscriptionStatus @default(PENDING_PAYMENT)
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  xenditInvoiceId    String?
  xenditPaymentUrl   String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
}
